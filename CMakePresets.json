{
    "version": 6,
    "configurePresets": [
        {
            "name": "msvc",
            "displayName": "MSVC (VS 2022)",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build",
            "environment": {
                "VULKAN_SDK": "C:/VulkanSDK/1.4.350.0"
            }
        },
        {
            "name": "linux",
            "displayName": "Linux (Ninja, gcc)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "configurePreset": "msvc",
            "configuration": "Release"
        },
        {
            "name": "debug",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux"
        }
    ],
    "testPresets": [
        {
            "name": "release",
            "configurePreset": "msvc",
            "configuration": "Release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "linux-release",
            "configurePreset": "linux",
            "output": { "outputOnFailure": true }
        }
    ]
}
